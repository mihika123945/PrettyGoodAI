# Google Gemini API
# Create a free-tier key at https://aistudio.google.com/app/apikey
# Do not enable billing if you want to remain on the free tier.
GEMINI_API_KEY=
LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
LIVE_VOICE=Kore
ANALYSIS_MODEL=gemini-2.5-flash-lite

# SignalWire
# Find these in your SignalWire Space dashboard.
SIGNALWIRE_SPACE_URL=your-space.signal
SIGNALWIRE_PROJECT_ID=
SIGNALWIRE_API_TOKEN= 
# Use one SignalWire number for every assessment call, in E.164 format.
SIGNALWIRE_FROM_NUMBER = 

# Public HTTPS origin forwarded to this application, without a trailing slash.
# Example: https://your-subdomain.ngrok-free.app
PUBLIC_BASE_URL=

# Safety: the application refuses every destination except this exact number.
ALLOWED_TEST_NUMBER=+18054398008

# Local settings
DATA_DIR=artifacts
MAX_CALL_SECONDS=240
LOG_LEVEL=INFO
